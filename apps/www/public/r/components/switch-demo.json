{
  "name": "switch-demo",
  "type": "registry:example",
  "registryDepends": ["switch"],
  "files": [
    {
      "path": "registry/examples/switch-demo.tsx",
      "content": "import { Switch } from \"@/registry/ui/switch\"\nimport { Description } from \"@/registry/ui/description\"\nimport { Field } from \"@/registry/ui/field\"\nimport { Label } from \"@/registry/ui/label\"\n\nexport default function SwitchDemo() {\n  return (\n    <div className=\"grid gap-4\">\n      <Field className=\"flex items-center gap-3\">\n        <Switch />\n        <Label>Airplane mode</Label>\n      </Field>\n      <Field className=\"flex items-center gap-3\">\n        <Switch defaultChecked />\n        <div>\n          <Label>Airplane mode</Label>\n          <Description>\n            Disable all network connections.\n          </Description>\n        </div>\n      </Field>\n      <Field disabled className=\"flex items-center gap-3\">\n        <Switch />\n        <Label>Airplane mode</Label>\n      </Field>\n    </div>\n  )\n}\n",
      "type": "registry:example"
    }
  ]
}
